<odoo>
    <!-- Inherit hr.employee form to add ticket-related fields -->
    <record id="view_employee_form_helpdesk" model="ir.ui.view">
        <field name="name">hr.employee.form.helpdesk</field>
        <field name="model">hr.employee</field>
        <field name="inherit_id" ref="hr.view_employee_form" />
        <field name="arch" type="xml">
            <xpath expr="//page[@name='personal_information']" position="after">
                <page string="Helpdesk">
                    <p class="oe_grey">Employee helpdesk ticket information</p>
                </page>
            </xpath>
        </field>
    </record>
</odoo>
